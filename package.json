{
  "name": "moonlight-client-spoof",
  "version": "1.3.1",
  "private": true,
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "clean": "node build.mjs --clean",
