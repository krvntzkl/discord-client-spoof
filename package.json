    "@moonlight-mod/eslint-config": "github:moonlight-mod/eslint-config",
    "esbuild": "^0.19.3",
    "eslint": "^9.12.0",
    "typescript": "^5.3.2"
  },
  "dependencies": {
    "@moonlight-mod/types": "1.0.0"
  }
}
