{
  "$schema": "https://moonlight-mod.github.io/manifest.schema.json",
  "id": "clientSpoof",
  "version": "1.3.1",
  "apiLevel": 2,
  "meta": {
    "name": "Client Spoof",
    "tagline": "Mask the visible client type (properties / presence)",
    "description": "**Client spoofer for Moonlight** - limits what people using platform-indicator plugins can infer about your real client; improves privacy. Code and releases: [GitHub](https://github.com/krvntzkl/discord-client-spoof).",
    "authors": ["krvntzkl"],
    "tags": ["privacy", "qol"],
    "source": "https://github.com/krvntzkl/discord-client-spoof"
  },
  "settings": {
    "profile": {
      "type": "select",
      "displayName": "Profile (browser → client status)",
      "description": "Each option uses an official `browser` name; presence shows as desktop, mobile, embedded, vr, or web. Legacy values `android` and `ios` are still accepted.",
      "default": "native",
      "advice": "reload",
      "options": [
        { "value": "native", "label": "Native — no spoofing" },
        { "value": "desktop", "label": "Discord Client → desktop" },
        { "value": "discord_android", "label": "Discord Android → mobile" },
        { "value": "discord_ios", "label": "Discord iOS → mobile" },
        { "value": "embedded", "label": "Discord Embedded → embedded" },
        { "value": "vr", "label": "Discord VR → vr" },
        { "value": "android_chrome", "label": "Android Chrome → web" },
        { "value": "android_mobile", "label": "Android Mobile → web" },
        { "value": "blackberry", "label": "BlackBerry → web" },
        { "value": "chrome", "label": "Chrome (desktop) → web" },
        { "value": "chrome_ios", "label": "Chrome iOS → web" },
        { "value": "edge", "label": "Edge (legacy) → web" },
        { "value": "facebook_mobile", "label": "Facebook Mobile → web" },
        { "value": "firefox", "label": "Firefox → web" },
        { "value": "internet_explorer", "label": "Internet Explorer → web" },
        { "value": "konqueror", "label": "Konqueror → web" },
        { "value": "mobile_safari", "label": "Mobile Safari → web" },
        { "value": "mozilla", "label": "Mozilla (generic) → web" },
        { "value": "opera", "label": "Opera → web" },
        { "value": "opera_mini", "label": "Opera Mini → web" },
        { "value": "safari", "label": "Safari (desktop) → web" }
      ]
    }
  }
}
